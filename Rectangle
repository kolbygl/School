from shapely.geometry import Point, Polygon
coords=[(0,0), (5,0), (5,10), (0,10)]
point1= Point(1,1)
point2=Point(13,5)
rectangle= Polygon(coords)

def pointContains(shape, point):
if shape.contains(point):
  print("point is inside of shape")
else:
  print("point is outside of shape")

print("Point in a polygon (Q5)")
pointContains(rectangle, point1)
pointContains(rectangle, point2)

